# IDE and editor files
.vscode
**/.vscode/sftp.json
.idea/
*.swp
*.swo
*~

# Local test/debug artifacts
.codex-local/
_remote_*

# Python caches
__pycache__/
**/__pycache__/
.pytest_cache/
.mypy_cache/

# Environment and secrets
.env
.env.*
!.env.example
!.env.*.example
sftp.json
settings.json

# Runtime state (must never be versioned)
/storage/
/tmp/
/sessions/
/backups/
/secrets/
/server-only/*
!/server-only/.gitignore
!/server-only/README.md

# Config policy: examples only
/config/*
!/config/examples/
!/config/examples/**

# Runtime/temp outputs
*.pid
*.tmp
*.log
logs/

# Dependency folders
node_modules/
vendor/

# OS-specific files
.DS_Store
Thumbs.db
Desktop.ini
