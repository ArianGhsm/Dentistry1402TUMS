# Copy to .env (or server environment) and fill real values.
# Keep production secrets out of git.
#
# Runtime paths (recommended: keep under server-only outside deploy/web root)
# DENT_SERVER_ONLY_ROOT=server-only
# DENT_STORAGE_ROOT=server-only/storage
# DENT_SESSION_SAVE_PATH=server-only/sessions

DENT_AUTH_SECRET_KEY=

# SMS provider integration
DENT_SMS_FARAZ_ENABLED=false
DENT_SMS_FARAZ_API_KEY=
DENT_SMS_FARAZ_PATTERN_CODE=
DENT_SMS_FARAZ_SENDER_LINE=
DENT_SMS_FARAZ_DOMAIN=
DENT_SMS_FARAZ_CODE_PARAM=code
DENT_SITE_DOMAIN=

# Payment integration
# available: mock | zarinpal
DENT_PAYMENT_GATEWAY=mock
DENT_PAYMENT_ZARINPAL_MERCHANT_ID=
DENT_PAYMENT_ZARINPAL_REQUEST_URL=
DENT_PAYMENT_ZARINPAL_VERIFY_URL=
DENT_PAYMENT_ZARINPAL_START_URL=
# optional webhook for owner notification integrations (sms/telegram/email bridge)
DENT_PAYMENT_NOTIFICATION_WEBHOOK=

# Chat media processing
DENT_CHAT_MEDIA_TARGET_MB=2
DENT_CHAT_FFMPEG_BIN=ffmpeg

# Navid integration
DENT_NAVID_SECRET_KEY=
DENT_NAVID_PYTHON_BIN=python
